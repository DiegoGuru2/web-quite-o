---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import Diccionario from '../components/Diccionario';
import Puteadas from '../components/Puteadas';
import TestQuiteno from '../components/TestQuiteno';
import Comentarios from '../components/Comentarios';
import { Sparkles } from 'lucide-react';

const API = 'https://lectorquite-o.vercel.app/api/v1';

// Fetch all data server-side (no CORS issues)
let wordsData = { total: 0, page: 0, size: 0, items: [] };
let quizData: any[] = [];

try {
  const [wordsRes, quizRes] = await Promise.all([
    fetch(`${API}/lexicon/words?skip=0&limit=100`),
    fetch(`${API}/lexicon/quiz/questions`),
  ]);
  if (wordsRes.ok) wordsData = await wordsRes.json();
  if (quizRes.ok) quizData = await quizRes.json();
} catch (e) {
  console.error('API fetch error:', e);
}
---

<BaseLayout 
  title="Inicio | Lector Quiteño" 
  description="El diccionario definitivo del dialecto quiteño. Aprende, ríe y pon a prueba tu verbo capitalino."
>
  <Navbar client:load />
  
  <Hero client:load />

  <Diccionario client:load initialData={wordsData} limit={4} />

  <Puteadas client:load initialWords={wordsData.items} />

  <TestQuiteno client:load questions={quizData} />

  <!-- Call to Action Section -->
  <section id="login-cta" class="section" style="padding: 100px 0;">
    <div class="container">
      <div class="card animate-fadeUp" style="padding: 60px; text-align: center; background: linear-gradient(135deg, var(--bg-card), rgba(212,160,23,0.05)); position: relative; overflow: hidden; border: 1px solid var(--gold);">
        <div style="position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(212,160,23,0.08) 0%, transparent 70%); border-radius: 999px;"></div>
        
        <Sparkles size={48} style={{ color: 'var(--gold)', margin: '0 auto 24px' }} />
        <h2 style="font-size: 38px; font-weight: 900; margin-bottom: 16px; font-family: var(--font-heading);">¡Únete al Gremio del <span class="text-gradient">Verbo</span> Quiteño!</h2>
        <p style="font-size: 18px; color: var(--text-secondary); max-width: 600px; margin: 0 auto 40px; line-height: 1.7;">
          Inicia sesión con tu correo para proponer nuevas palabras, votar por los mejores quiteñismos y participar en la comunidad.
        </p>
        
        <div style="display: flex; justify-content: center; gap: 20px; flex-wrap: wrap;">
          <a href="/login" class="btn-gold" style="padding: 16px 40px; font-size: 16px; text-decoration: none;">
            🔐 Iniciar Sesión
          </a>
        </div>
      </div>
    </div>
  </section>

  <Comentarios client:load initialWords={wordsData.items} />

  <footer style="padding: 80px 0 40px; border-top: 1px solid var(--border); background: var(--bg-secondary); margin-top: 100px;">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 48px; margin-bottom: 60px;">
        <div style="max-width: 320px;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
            <div style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, var(--gold), #e6a800); display: flex; align-items: center; justify-content: center; color: var(--blue-deep); font-weight: 900; font-size: 14px; font-family: var(--font-heading);">Q</div>
            <span style="font-size: 22px; font-weight: 950; font-family: var(--font-heading); letter-spacing: -0.5px;">Lector<span style="color: var(--gold);">Quiteño</span></span>
          </div>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.7;">
            Preservando el patrimonio lingüístico de la Carita de Dios. Porque el quiteño no habla, ¡da cátedra!
          </p>
        </div>
        
        <div style="display: flex; gap: 60px; flex-wrap: wrap;">
          <div>
            <h4 style="font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); margin-bottom: 24px;">Contenido</h4>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px;">
              <li><a href="#diccionario" style="font-size: 14px; color: var(--text-secondary); text-decoration: none;">Diccionario</a></li>
              <li><a href="#puteadas" style="font-size: 14px; color: var(--text-secondary); text-decoration: none;">Invectivas</a></li>
              <li><a href="#test" style="font-size: 14px; color: var(--text-secondary); text-decoration: none;">Trivia Quiz</a></li>
            </ul>
          </div>
          <div>
            <h4 style="font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); margin-bottom: 24px;">Comunidad</h4>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px;">
              <li><a href="#comentarios" style="font-size: 14px; color: var(--text-secondary); text-decoration: none;">Comentarios</a></li>
              <li><a href="/admin" style="font-size: 14px; color: var(--text-secondary); text-decoration: none;">Panel Admin</a></li>
            </ul>
          </div>
        </div>
      </div>
      
      <div style="padding-top: 32px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
        <span style="font-size: 13px; color: var(--text-muted); font-weight: 500;">&copy; 2026 Lector Quiteño • Hecho en la Mitad del Mundo 🇪🇨</span>
        <div style="display: flex; gap: 24px;">
          <a href="https://lectorquite-o.vercel.app/docs" target="_blank" style="font-size: 12px; color: var(--text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none;">API Docs</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    import { getSupabase } from '../services/supabase';
    const sb = getSupabase();
    if (sb) {
      sb.auth.getSession().then(({ data: { session } }) => {
        if (session) {
          const cta = document.getElementById('login-cta');
          if (cta) cta.style.display = 'none';
        }
      });
    }
  </script>
</BaseLayout>
