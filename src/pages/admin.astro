---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import AdminDashboard from '../components/AdminDashboard';
import { Shield } from 'lucide-react';

const API = 'https://lectorquite-o.vercel.app/api/v1';
let initialWords = { total: 0, items: [] };
let initialQuestions: any[] = [];

try {
  const [wRes, qRes] = await Promise.all([
    fetch(`${API}/lexicon/words?skip=0&limit=100`),
    fetch(`${API}/lexicon/quiz/questions`)
  ]);
  if (wRes.ok) initialWords = await wRes.json();
  if (qRes.ok) initialQuestions = await qRes.json();
} catch(e) {}
---

<BaseLayout 
  title="Panel Administrativo | Lector Quiteño" 
  description="Gestión oficial y moderación del Lector Quiteño. Solo para administradores autenticados."
>
  <Navbar client:load />
  
  <main class="page-container" style="padding-top: 120px; padding-bottom: 80px;">
     <header style="margin-bottom: 48px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 12px;">
           <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(212,160,23,0.1); display: flex; align-items: center; justify-content: center; color: var(--gold); border: 1px solid rgba(212,160,23,0.2);">
              <Shield size={22} strokeWidth={2.5} />
           </div>
           <span style="font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.25em; color: var(--gold);">
              Terminal de Operaciones
           </span>
        </div>
        
        <h1 style="font-size: 52px; font-weight: 800; font-family: var(--font-heading); line-height: 1.1; margin-bottom: 16px;">
           Centro de <span class="text-gradient">Mando</span>
        </h1>
        <p style="font-size: 16px; color: var(--text-secondary); max-width: 600px; line-height: 1.6;">
           Gestiona el léxico capitalino, aprueba nuevas propuestas y modera la comunidad del Chulla Quiteño.
        </p>
     </header>
     
     <AdminDashboard client:load initialWords={initialWords} initialQuestions={initialQuestions} />
  </main>

  <footer style="padding: 48px 0; border-top: 1px solid var(--border); background: var(--bg-secondary); margin-top: 80px;">
    <div class="container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px;">
      <div style="display: flex; align-items: center; gap: 10px;">
        <div style="width: 26px; height: 26px; border-radius: 7px; background: linear-gradient(135deg, var(--gold), #e6a800); display: flex; align-items: center; justify-content: center; color: var(--blue-deep); font-weight: 900; font-size: 12px; font-family: var(--font-heading);">Q</div>
        <span style="font-size: 13px; color: var(--text-muted); font-weight: 500;">&copy; 2026 Admin Panel • Lector Quiteño</span>
      </div>
      <div style="display: flex; gap: 28px;">
        <a href="/" style="font-size: 12px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none;">Volver al Sitio</a>
        <a href="https://lectorquite-o.vercel.app/docs" target="_blank" style="font-size: 12px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none;">Documentación API</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding-left: 24px;
    padding-right: 24px;
  }
  
  @media (max-width: 768px) {
    .page-container {
      padding-top: 100px;
    }
    h1 {
      font-size: 38px !important;
    }
  }
</style>
