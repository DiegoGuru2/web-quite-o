---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Iniciar Sesión">
  <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px; background: var(--bg-primary);">
    <div style="width: 100%; max-width: 460px;">

      <!-- Header -->
      <div style="margin-bottom: 36px;">
        <a href="/" style="display: inline-flex; align-items: center; gap: 10px; margin-bottom: 40px; text-decoration: none;">
          <div style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, var(--gold), #e6a800); display: flex; align-items: center; justify-content: center; color: var(--blue-deep); font-weight: 900; font-size: 14px; font-family: var(--font-heading);">Q</div>
          <span style="font-size: 18px; font-weight: 800; font-family: var(--font-heading); letter-spacing: -0.5px;">Lector<span style="color: var(--gold);">Quiteño</span></span>
        </a>
        <h1 style="font-size: 28px; font-weight: 900; font-family: var(--font-heading); margin-bottom: 8px; color: var(--text-primary);">Iniciar sesión</h1>
        <p style="font-size: 15px; color: var(--text-secondary);">Accede con Google, Facebook o tu correo.</p>
      </div>

      <!-- Social buttons -->
      <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px;">
        <button id="btn-google" style="display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; padding: 14px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 15px; font-weight: 600; cursor: pointer; transition: border-color 0.2s;">
          <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg>
          Continuar con Google
        </button>
        <button id="btn-facebook" style="display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; padding: 14px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 15px; font-weight: 600; cursor: pointer; transition: border-color 0.2s;">
          <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#1877F2" d="M24 4C12.954 4 4 12.954 4 24c0 9.983 7.314 18.257 16.878 19.757v-13.98h-5.08V24h5.08v-4.406c0-5.013 2.986-7.781 7.554-7.781 2.188 0 4.477.39 4.477.39v4.921h-2.522c-2.484 0-3.259 1.542-3.259 3.123V24h5.547l-.887 5.777h-4.66v13.98C36.686 42.257 44 33.983 44 24c0-11.046-8.954-20-20-20z"/></svg>
          Continuar con Facebook
        </button>
      </div>

      <!-- Divider -->
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 28px;">
        <div style="flex: 1; height: 1px; background: var(--border);"></div>
        <span style="font-size: 13px; color: var(--text-muted); font-weight: 500;">o con correo</span>
        <div style="flex: 1; height: 1px; background: var(--border);"></div>
      </div>

      <!-- Form -->
      <form id="login-form" style="display: flex; flex-direction: column; gap: 20px;">
        <!-- Name (only for register) -->
        <div id="name-field" style="display: none; flex-direction: column; gap: 8px;">
          <label style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Nombre completo</label>
          <input id="input-name" type="text" placeholder="Tu nombre, veci..." style="width: 100%; padding: 14px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 15px; outline: none; font-family: var(--font-body); transition: border-color 0.2s;" />
        </div>

        <div style="display: flex; flex-direction: column; gap: 8px;">
          <label style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Correo electrónico</label>
          <input id="input-email" type="email" required placeholder="tu@correo.com" style="width: 100%; padding: 14px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 15px; outline: none; font-family: var(--font-body); transition: border-color 0.2s;" />
        </div>

        <div style="display: flex; flex-direction: column; gap: 8px;">
          <label style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Contraseña</label>
          <input id="input-password" type="password" required placeholder="••••••••" style="width: 100%; padding: 14px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 15px; outline: none; font-family: var(--font-body); transition: border-color 0.2s;" />
        </div>

        <!-- Message -->
        <div id="auth-message" style="display: none; padding: 12px 16px; border-radius: 10px; font-size: 13px; font-weight: 600;"></div>

        <button id="btn-submit" type="submit" style="width: 100%; padding: 16px; border-radius: 10px; border: none; background: #6aafe6; color: #fff; font-size: 16px; font-weight: 700; cursor: pointer; transition: background 0.2s; font-family: var(--font-body);">
          Entrar
        </button>
      </form>

      <!-- Toggle register/login -->
      <div style="text-align: center; margin-top: 28px; font-size: 14px; color: var(--text-secondary);">
        <span id="toggle-text">¿No tienes cuenta?</span>
        <button id="btn-toggle" style="background: none; border: none; color: #3b82f6; font-weight: 700; font-size: 14px; cursor: pointer; margin-left: 4px; font-family: var(--font-body);">Crear cuenta</button>
      </div>

    </div>
  </div>

  <style>
    input:focus {
      border-color: var(--gold) !important;
      box-shadow: 0 0 0 3px rgba(212,160,23,0.1);
    }
    button:hover {
      opacity: 0.92;
    }
    #btn-google:hover, #btn-facebook:hover {
      border-color: var(--text-muted) !important;
    }
    #btn-submit:hover {
      background: #5a9fd6 !important;
    }
  </style>

  <script>
    import { getSupabase } from '../services/supabase';

    let isRegister = false;

    const form = document.getElementById('login-form') as HTMLFormElement;
    const nameField = document.getElementById('name-field') as HTMLDivElement;
    const inputName = document.getElementById('input-name') as HTMLInputElement;
    const inputEmail = document.getElementById('input-email') as HTMLInputElement;
    const inputPassword = document.getElementById('input-password') as HTMLInputElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;
    const btnToggle = document.getElementById('btn-toggle') as HTMLButtonElement;
    const toggleText = document.getElementById('toggle-text') as HTMLSpanElement;
    const msgBox = document.getElementById('auth-message') as HTMLDivElement;

    function showMsg(text: string, type: 'success' | 'error') {
      msgBox.textContent = text;
      msgBox.style.display = 'block';
      msgBox.style.background = type === 'success' ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)';
      msgBox.style.color = type === 'success' ? '#22c55e' : '#ef4444';
    }

    // Toggle register/login
    btnToggle.addEventListener('click', () => {
      isRegister = !isRegister;
      if (isRegister) {
        nameField.style.display = 'flex';
        inputName.required = true;
        btnSubmit.textContent = 'Crear cuenta';
        toggleText.textContent = '¿Ya tienes cuenta?';
        btnToggle.textContent = 'Iniciar sesión';
        const h1 = document.querySelector('h1');
        if (h1) h1.textContent = 'Crear cuenta';
      } else {
        nameField.style.display = 'none';
        inputName.required = false;
        btnSubmit.textContent = 'Entrar';
        toggleText.textContent = '¿No tienes cuenta?';
        btnToggle.textContent = 'Crear cuenta';
        const h1 = document.querySelector('h1');
        if (h1) h1.textContent = 'Iniciar sesión';
      }
      msgBox.style.display = 'none';
    });

    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const sb = getSupabase();
      if (!sb) { showMsg('Error de configuración de Supabase.', 'error'); return; }

      btnSubmit.disabled = true;
      btnSubmit.textContent = 'Cargando...';

      if (isRegister) {
        const { error } = await sb.auth.signUp({
          email: inputEmail.value,
          password: inputPassword.value,
          options: { data: { full_name: inputName.value } }
        });
        if (error) {
          showMsg(error.message, 'error');
        } else {
          showMsg('¡Cuenta creada, veci! Ya puedes iniciar sesión.', 'success');
          // Switch to login mode
          setTimeout(() => btnToggle.click(), 2000);
        }
      } else {
        const { error } = await sb.auth.signInWithPassword({
          email: inputEmail.value,
          password: inputPassword.value,
        });
        if (error) {
          showMsg(error.message, 'error');
        } else {
          window.location.href = '/';
        }
      }

      btnSubmit.disabled = false;
      btnSubmit.textContent = isRegister ? 'Crear cuenta' : 'Entrar';
    });

    // Google OAuth
    document.getElementById('btn-google')?.addEventListener('click', async () => {
      const sb = getSupabase();
      if (!sb) return;
      await sb.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: window.location.origin }
      });
    });

    // Facebook OAuth
    document.getElementById('btn-facebook')?.addEventListener('click', async () => {
      const sb = getSupabase();
      if (!sb) return;
      await sb.auth.signInWithOAuth({
        provider: 'facebook',
        options: { redirectTo: window.location.origin }
      });
    });

    // If already logged in, redirect home
    const sb = getSupabase();
    if (sb) {
      sb.auth.getSession().then(({ data: { session } }) => {
        if (session) window.location.href = '/';
      });
    }
  </script>
</BaseLayout>
